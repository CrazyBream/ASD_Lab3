@model ASD_Lab3.PL.Models.ArticleCreateViewModel
@{
    ViewData["Title"] = "Написати статтю";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-4 p-4">
            <h3 class="fw-bold mb-4 text-center">Створити новий допис <i class="bi bi-stars text-warning"></i></h3>

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Title" class="form-control fw-bold fs-5" id="floatingTitle" placeholder="Заголовок..." />
                    <label for="floatingTitle">Крутий заголовок</label>
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="CategoryName" class="form-control text-primary fw-bold" id="floatingCategory" placeholder="Тег..." />
                    <label for="floatingCategory"><i class="bi bi-hash"></i> Рубрика / Тег (напр. Програмування, Новини)</label>
                    <span asp-validation-for="CategoryName" class="text-danger small"></span>
                </div>

                <div class="mb-4 bg-light p-3 rounded-3 border">
                    <label asp-for="ImageFile" class="form-label fw-bold text-dark mb-2">
                        <i class="bi bi-cloud-upload text-primary me-1"></i> Обкладинка статті
                    </label>
                    <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
                    <div class="form-text mt-2"><i class="bi bi-info-circle"></i> Виберіть красиве фото (JPG, PNG). Це необов'язково.</div>
                </div>

                <div class="form-group mb-4">
                    <label class="form-label fw-bold text-muted mb-2">Основний текст статті</label>
                    <textarea asp-for="Content" class="form-control" rows="8" placeholder="Про що хочете розповісти світу?..."></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-light rounded-pill px-4">Скасувати</a>
                    <button type="submit" class="btn btn-custom rounded-pill px-5">
                        Опублікувати <i class="bi bi-send-fill ms-1"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}