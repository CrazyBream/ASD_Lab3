@model ASD_Lab3.BLL.DTO.ArticleDTO
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Title;
    var userIdClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    bool isOwner = userIdClaim != null && Model.UserId.ToString() == userIdClaim;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-9">

            <div id="viewMode" class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="w-100" style="max-height: 400px; object-fit: cover;" alt="Обкладинка">
                }
                else
                {
                    <img src="https://picsum.photos/seed/@Model.Id/900/400" class="w-100" style="max-height: 400px; object-fit: cover;" alt="Обкладинка">
                }

                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="badge bg-primary text-uppercase px-3 py-2 rounded-pill">
                            <i class="bi bi-hash"></i> @Model.CategoryName
                        </span>

                        @if (isOwner)
                        {
                            <div class="d-flex gap-2">
                                <button type="button" id="btnEnableEdit" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                                    <i class="bi bi-pencil"></i> Редагувати
                                </button>
                                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Ви впевнені, що хочете видалити цей допис?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                        <i class="bi bi-trash"></i> Видалити
                                    </button>
                                </form>
                            </div>
                        }
                    </div>

                    <h1 class="fw-bold mb-3">@Model.Title</h1>

                    <div class="d-flex align-items-center text-muted small mb-4 border-bottom pb-3">
                        <img src="https://ui-avatars.com/api/?name=@Model.AuthorName&background=random" class="rounded-circle me-2" width="32" height="32">
                        <span class="fw-bold text-dark me-3">@Model.AuthorName</span>
                        <span><i class="bi bi-calendar3 me-1"></i> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>

                    <div class="article-content fs-5 lh-base" style="white-space: pre-line;">
                        @Model.Content
                    </div>
                </div>
            </div>

            @if (isOwner)
            {
                <div id="editMode" class="card shadow-sm border-0 rounded-4 p-4 mb-4 d-none">
                    <h3 class="fw-bold mb-4">Редагування допису</h3>
                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="form-floating mb-3">
                            <input name="Title" value="@Model.Title" class="form-control fw-bold" id="editTitle" placeholder="Заголовок" required />
                            <label for="editTitle">Заголовок статті</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input name="CategoryName" value="@Model.CategoryName" class="form-control text-primary fw-bold" id="editCategory" placeholder="Рубрика" required />
                            <label for="editCategory">Рубрика / Тег</label>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted small"><i class="bi bi-image"></i> Змінити обкладинку (необов'язково)</label>
                            <input name="ImageFile" class="form-control form-control-sm" type="file" accept="image/*" />
                        </div>

                        <div class="form-group mb-4">
                            <label class="form-label fw-bold text-muted mb-2">Текст статті</label>
                            <textarea name="Content" class="form-control" rows="10" required>@Model.Content</textarea>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" id="btnCancelEdit" class="btn btn-light rounded-pill px-4">Скасувати</button>
                            <button type="submit" class="btn btn-dark rounded-pill px-4">Зберегти зміни</button>
                        </div>
                    </form>
                </div>
            }

            <div class="card shadow-sm border-0 rounded-4 p-4 mb-4">
                <h4 class="fw-bold mb-4"><i class="bi bi-chat-left-text me-2"></i>Коментарі</h4>

                @if (User.Identity.IsAuthenticated)
                {
                    <form asp-controller="Comment" asp-action="Create" method="post" class="mb-4">
                        <input type="hidden" name="articleId" value="@Model.Id" />
                        <div class="form-group mb-2">
                            <textarea name="text" class="form-control bg-light border-0" rows="3" placeholder="Написати коментар..." required></textarea>
                        </div>
                        <div class="text-end">
                            <button type="submit" class="btn btn-dark rounded-pill px-4">Відправити</button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="alert alert-secondary text-center rounded-3">
                        <a asp-controller="Account" asp-action="Login" class="text-decoration-none fw-bold text-dark">Увійдіть</a>, щоб залишити коментар.
                    </div>
                }

                <div>
                    @if (ViewBag.Comments != null)
                    {
                        await RenderComments((IEnumerable<ASD_Lab3.BLL.DTO.CommentDTO>)ViewBag.Comments, Model.Id, userIdClaim);
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@functions {
    async Task RenderComments(IEnumerable<ASD_Lab3.BLL.DTO.CommentDTO> comments, int articleId, string currentUserId)
    {
        foreach (var comment in comments)
        {
            <div class="mt-3 p-3 border rounded-3 bg-white" style="margin-left: @(comment.ParentCommentId.HasValue ? "40px" : "0"); border-left: @(comment.ParentCommentId.HasValue ? "3px solid #dee2e6 !important" : "")">
                <div class="d-flex justify-content-between mb-2">
                    <span class="fw-bold text-primary">@comment.AuthorName</span>
                    <span class="text-muted small">@comment.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                </div>

                <p class="mb-2 text-dark">@comment.Text</p>

                <div class="d-flex gap-3 align-items-center">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <button class="btn btn-sm btn-link p-0 text-decoration-none text-muted fw-bold" onclick="document.getElementById('reply-form-@comment.Id').classList.toggle('d-none')">Відповісти</button>
                    }

                    @if (currentUserId == comment.UserId.ToString())
                    {
                        <button class="btn btn-sm btn-link text-secondary p-0 text-decoration-none fw-bold" onclick="document.getElementById('edit-form-@comment.Id').classList.toggle('d-none')">Редагувати</button>

                        <form asp-controller="Comment" asp-action="Delete" method="post" class="m-0" onsubmit="return confirm('Видалити цей коментар?');">
                            <input type="hidden" name="id" value="@comment.Id" />
                            <input type="hidden" name="articleId" value="@articleId" />
                            <button type="submit" class="btn btn-sm btn-link text-danger p-0 text-decoration-none fw-bold">Видалити</button>
                        </form>
                    }
                </div>

                <div id="edit-form-@comment.Id" class="d-none mt-3">
                    <form asp-controller="Comment" asp-action="Edit" method="post">
                        <input type="hidden" name="articleId" value="@articleId" />
                        <input type="hidden" name="id" value="@comment.Id" />
                        <div class="d-flex gap-2">
                            <input type="text" name="text" class="form-control form-control-sm border-secondary" value="@comment.Text" required />
                            <button type="submit" class="btn btn-secondary btn-sm rounded-pill px-3">Зберегти</button>
                        </div>
                    </form>
                </div>

                <div id="reply-form-@comment.Id" class="d-none mt-3">
                    <form asp-controller="Comment" asp-action="Create" method="post">
                        <input type="hidden" name="articleId" value="@articleId" />
                        <input type="hidden" name="parentCommentId" value="@comment.Id" />
                        <div class="d-flex gap-2">
                            <input type="text" name="text" class="form-control form-control-sm bg-light border-0" placeholder="Ваша відповідь..." required />
                            <button type="submit" class="btn btn-dark btn-sm rounded-pill px-3">Відправити</button>
                        </div>
                    </form>
                </div>

                @if (comment.Replies != null && comment.Replies.Any())
                {
                    <div class="mt-2">
                        @{
                            await RenderComments(comment.Replies, articleId, currentUserId);
                        }
                    </div>
                }
            </div>
        }
    }
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const btnEnableEdit = document.getElementById("btnEnableEdit");
            const btnCancelEdit = document.getElementById("btnCancelEdit");
            const viewMode = document.getElementById("viewMode");
            const editMode = document.getElementById("editMode");

            if (btnEnableEdit && btnCancelEdit) {
                btnEnableEdit.addEventListener("click", function () {
                    viewMode.classList.add("d-none");
                    editMode.classList.remove("d-none");
                });

                btnCancelEdit.addEventListener("click", function () {
                    editMode.classList.add("d-none");
                    viewMode.classList.remove("d-none");
                });
            }
        });
    </script>
}