@{
    ViewData["Title"] = "БлогІТ - Твій простір ідей";
}

<div class="container py-5 mt-4">
    <div class="row align-items-center justify-content-center text-center mb-5 pb-4">
        <div class="col-lg-9">
            <div class="d-inline-block mb-3 px-3 py-1 rounded-pill bg-white shadow-sm border" style="font-size: 0.85rem; font-weight: 600; color: #764ba2;">
                <i class="bi bi-stars text-warning me-1"></i> Версія 1.0 вже доступна!
            </div>

            <h1 class="display-3 fw-bold mb-4" style="letter-spacing: -1px;">
                Твій простір для <span class="gradient-text">крутих ідей</span> та коду
            </h1>

            <p class="lead text-muted mb-5 fs-4 px-md-5">
                БлогІТ — це сучасна українська платформа для розробників та ентузіастів. Читайте цікаві статті, діліться власним досвідом та знаходьте однодумців.
            </p>

            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-controller="Article" asp-action="Index" class="btn btn-dark btn-lg rounded-pill px-5 shadow-sm fw-bold">
                    Читати стрічку <i class="bi bi-arrow-right ms-2"></i>
                </a>

                @if (!User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary btn-lg rounded-pill px-5 fw-bold" style="border-color: #667eea; color: #667eea;">
                        Приєднатися
                    </a>
                }
                else
                {
                    <a asp-controller="Article" asp-action="Create" class="btn btn-custom btn-lg rounded-pill px-5 fw-bold">
                        Написати статтю <i class="bi bi-pencil-square ms-2"></i>
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2 text-center">
        <div class="col-md-4">
            <div class="p-4 bg-white rounded-4 shadow-sm h-100" style="transition: transform 0.3s; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-4" style="width: 70px; height: 70px;">
                    <i class="bi bi-journal-richtext fs-2" style="color: #667eea;"></i>
                </div>
                <h4 class="fw-bold mb-3">Ділися думками</h4>
                <p class="text-muted mb-0">Пиши статті з багатим форматуванням, додавай яскраві обкладинки та теги для зручного пошуку.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="p-4 bg-white rounded-4 shadow-sm h-100" style="transition: transform 0.3s; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-4" style="width: 70px; height: 70px;">
                    <i class="bi bi-chat-quote fs-2 text-success"></i>
                </div>
                <h4 class="fw-bold mb-3">Спілкуйся</h4>
                <p class="text-muted mb-0">Наша система багаторівневих коментарів дозволяє вести зручні дискусії під кожним дописом.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="p-4 bg-white rounded-4 shadow-sm h-100" style="transition: transform 0.3s; cursor: pointer;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-4" style="width: 70px; height: 70px;">
                    <i class="bi bi-person-badge fs-2 text-warning"></i>
                </div>
                <h4 class="fw-bold mb-3">Будуй бренд</h4>
                <p class="text-muted mb-0">Налаштовуй свій особистий профіль, додавай аватарку та біографію, щоб тебе впізнавали.</p>
            </div>
        </div>
    </div>
</div>